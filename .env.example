# Copy this file to ".env" (same folder) and fill in your values.
# The backend loads .env automatically on startup. .env is git-ignored.

# --- Google Gemini fallback (used when Ollama isn't running) ---
# Get a key at https://aistudio.google.com/apikey  (leave blank to skip Gemini)
GEMINI_API_KEY=
# Optional: pin a model (default is gemini-3.5-flash)
# GEMINI_MODEL=gemini-3.5-flash

# --- Trained model paths (so you don't pass them on the command line) ---
TEXT_MODEL_DIR=models/weights/text
FACE_MODEL_PATH=models/weights/face/face_net.pt

# --- LLM backend: auto (default) | ollama | gemini | template ---
# LLM_BACKEND=auto
